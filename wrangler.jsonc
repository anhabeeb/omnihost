{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "omnihost",
  "main": "worker/index.ts",
  "compatibility_date": "2026-04-10",
  "compatibility_flags": ["nodejs_compat_v2"],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "vars": {
    "APP_NAME": "OmniHost",
    "APP_TAGLINE": "Hospitality operations in one live control center.",
    "APP_CURRENCY": "USD",
    "APP_BASE_URL": "http://localhost:5173",
    "EMAIL_PROVIDER": "mock",
    "DEFAULT_FROM_EMAIL": "ops@omnihost.app",
    "DEFAULT_REPLY_TO_EMAIL": "hello@omnihost.app",
    "QUOTE_PREFIX": "QTN",
    "INVOICE_PREFIX": "INV"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "omnihost",
      "database_id": "3669dd93-d4f2-4549-b2c9-177e1590b6ae",
      "preview_database_id": "3669dd93-d4f2-4549-b2c9-177e1590b6ae",
      "migrations_dir": "./migrations"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "BOOKING_SYNC",
        "class_name": "BookingSyncHub"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["BookingSyncHub"]
    }
  ]
}
